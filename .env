# Host-specific configuration — copy to .env and fill in before running setup.sh
# .env is git-ignored; never commit real values here.

# User/group IDs for container file ownership (match your host user)
PUID=1000
PGID=1000

# Timezone for container logs and scheduled tasks
TZ=America/New_York

# Media library paths (bind-mounted into containers)
MEDIA_BOOKS=/srv/media/books
MEDIA_AUDIO=/srv/media/audiobooks

# Config volume paths on the host
KAVITA_CONFIG=/srv/config/kavita
ABS_CONFIG=/srv/config/audiobookshelf

# Exposed ports
KAVITA_PORT=5000
ABS_PORT=13378